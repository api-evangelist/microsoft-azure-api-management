{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCPResponse",
  "type": "object",
  "properties": {
    "jsonrpc": {
      "type": "string",
      "example": "2.0"
    },
    "id": {
      "type": "integer",
      "example": 1
    },
    "result": {
      "type": "object",
      "properties": {
        "content": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "example": "text"
              },
              "text": {
                "type": "string",
                "example": "The weather in Seattle is 62F and partly cloudy."
              }
            }
          }
        }
      }
    }
  }
}
