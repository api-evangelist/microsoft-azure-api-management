{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatCompletionRequest",
  "type": "object",
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "example": "user"
          },
          "content": {
            "type": "string",
            "example": "What is Azure API Management?"
          }
        }
      }
    },
    "max_tokens": {
      "type": "integer",
      "example": 256
    },
    "temperature": {
      "type": "number",
      "example": 0.7
    }
  }
}
